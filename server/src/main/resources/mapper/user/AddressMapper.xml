<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.payserver.module.user.mapper.AddressMapper">

    <select id="findById" resultType="com.payserver.module.user.model.entity.UserAddress">
        SELECT id, user_id, receiver, phone, province, city, district, detail, is_default, create_time
        FROM user_address
        WHERE id = #{id}
    </select>
</mapper>
